Grammar

    0 $accept: program $end

    1 program: global_list

    2 global_list: global_list global
    3            | global

    4 global: var_decl
    5       | func_decl
    6       | struct_decl
    7       | extern_decl

    8 extern_decl: EXTERN VAR IDENTIFIER ';'

    9 struct_decl: STRUCT IDENTIFIER '{' var_decl_list '}' ';'

   10 var_decl_list: var_decl_list var_decl
   11              | var_decl

   12 var_decl: VAR var_init_list ';'

   13 var_init_list: var_init_list ',' var_init
   14              | var_init

   15 var_init: IDENTIFIER
   16         | IDENTIFIER '=' expression
   17         | IDENTIFIER '[' INT_CONST ']'
   18         | IDENTIFIER '[' INT_CONST ']' '=' '{' expression_list '}'

   19 func_decl: FUNC IDENTIFIER '(' param_list ')' block
   20          | FUNC IDENTIFIER '(' ')' block

   21 param_list: param_list ',' param
   22           | param

   23 param: VAR IDENTIFIER

   24 block: '{' statement_list '}'

   25 statement_list: statement_list statement
   26               | statement

   27 statement: var_decl
   28          | assignment ';'
   29          | expression ';'
   30          | block
   31          | loop_stmt
   32          | switch_stmt
   33          | BREAK ';'
   34          | CONTINUE ';'
   35          | RETURN expression ';'
   36          | IF '(' expression ')' statement
   37          | IF '(' expression ')' statement ELSE statement
   38          | error ';'
   39          | error '}'

   40 assignment: lvalue '=' expression

   41 lvalue: IDENTIFIER
   42       | IDENTIFIER '[' expression ']'
   43       | IDENTIFIER '.' IDENTIFIER
   44       | IDENTIFIER PTR_OP IDENTIFIER
   45       | '*' IDENTIFIER

   46 loop_stmt: WHILE '(' expression ')' statement
   47          | DO statement WHILE '(' expression ')' ';'
   48          | FOR '(' assignment ';' expression ';' assignment ')' statement

   49 switch_stmt: SWITCH '(' expression ')' '{' case_list '}'

   50 case_list: case_list case_block
   51          | case_block

   52 case_block: CASE INT_CONST ':' statement_list
   53           | DEFAULT ':' statement_list

   54 expression_list: expression_list ',' expression
   55                | expression

   56 expression: logical_or_expr

   57 logical_or_expr: logical_or_expr OR_OP logical_and_expr
   58                | logical_and_expr

   59 logical_and_expr: logical_and_expr AND_OP bitwise_or_expr
   60                 | bitwise_or_expr

   61 bitwise_or_expr: bitwise_or_expr '|' bitwise_xor_expr
   62                | bitwise_xor_expr

   63 bitwise_xor_expr: bitwise_xor_expr '^' bitwise_and_expr
   64                 | bitwise_and_expr

   65 bitwise_and_expr: bitwise_and_expr '&' equality_expr
   66                 | equality_expr

   67 equality_expr: equality_expr EQ_OP relational_expr
   68              | equality_expr NE_OP relational_expr
   69              | relational_expr

   70 relational_expr: relational_expr '<' shift_expr
   71                | relational_expr '>' shift_expr
   72                | relational_expr LE_OP shift_expr
   73                | relational_expr GE_OP shift_expr
   74                | shift_expr

   75 shift_expr: shift_expr SHL_OP additive_expr
   76           | shift_expr SHR_OP additive_expr
   77           | additive_expr

   78 additive_expr: additive_expr '+' multiplicative_expr
   79              | additive_expr '-' multiplicative_expr
   80              | multiplicative_expr

   81 multiplicative_expr: multiplicative_expr '*' unary_expr
   82                    | multiplicative_expr '/' unary_expr
   83                    | multiplicative_expr '%' unary_expr
   84                    | unary_expr

   85 unary_expr: '-' unary_expr
   86           | '!' unary_expr
   87           | '~' unary_expr
   88           | '*' unary_expr
   89           | '&' unary_expr
   90           | postfix_expr

   91 postfix_expr: postfix_expr INC_OP
   92             | postfix_expr DEC_OP
   93             | primary_expr

   94 primary_expr: IDENTIFIER
   95             | IDENTIFIER '(' argument_list ')'
   96             | IDENTIFIER '(' ')'
   97             | IDENTIFIER '[' expression ']'
   98             | INT_CONST
   99             | FLOAT_CONST
  100             | CHAR_CONST
  101             | STRING_LITERAL
  102             | SIZEOF '(' expression ')'
  103             | '(' expression ')'

  104 argument_list: argument_list ',' expression
  105              | expression


